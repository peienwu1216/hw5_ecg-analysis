# ==============================================================
# .gitignore — HRV Single-Lead ECG Analysis Repository
# ==============================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
*.manifest

# ---- Virtual environments ----
.venv/
venv/
ENV/

# ---- Jupyter ----
.ipynb_checkpoints/

# ---- OS / editor ----
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# ---- Env & local secrets ----
.env
.env.*
*.pem

# ---- Local IDE / AI assistant configs ----
.claude/
.cursor/
.cursorrules
CLAUDE.md
CURSOR.md
CURSORRULES.md

# ---- Non-project files (reference PDFs, homework specs, dev notes) ----
Edwin/
Heart-rate-variability-guidelines.pdf
hw_spec.txt
patch.md
texput.log

# ---- Raw data (health-related, not distributed) ----
# Remove if using a private repo with Git LFS for data versioning.
data-new/

# ---- LaTeX build artifacts (manuscript/) ----
manuscript/build/
manuscript/*.aux
manuscript/*.log
manuscript/*.pdf
manuscript/*.synctex.gz
manuscript/*.fdb_latexmk
manuscript/*.fls
manuscript/*.out
manuscript/*.toc
manuscript/*.lof
manuscript/*.lot
manuscript/*.bbl
manuscript/*.blg
manuscript/*.bcf
manuscript/*.run.xml

# ---- Internal dev notes (not part of the public repo) ----
manuscript/notes/FIGURE_ANALYSIS_REPORT.md
manuscript/notes/FIGURE_TABLE_PLAN.md
manuscript/notes/OVERLEAF_SETUP.md
scripts/preflight_report.md
