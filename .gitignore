data-new/

# --- LaTeX (manuscript/) ---
# Track: main.tex, latexmkrc, README.md, notes/**
# Ignore: PDF + aux from latexmk / pdflatex (primary: manuscript/build/ via `build/` above).
manuscript/build/
manuscript/*.aux
manuscript/*.log
manuscript/*.pdf
manuscript/*.synctex.gz
manuscript/*.fdb_latexmk
manuscript/*.fls
manuscript/*.out
manuscript/*.toc
manuscript/*.lof
manuscript/*.lot
manuscript/*.bbl
manuscript/*.blg
manuscript/*.bcf
manuscript/*.run.xml
