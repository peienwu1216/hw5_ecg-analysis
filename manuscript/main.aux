\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces Walking vs.\ seated-baseline RR power spectral density contrast. Walking shows near-collapse of HF power together with broadening of the LF region, consistent with sympathetic activation plus motion-related spectral spreading.}}{12}{}\protected@file@percent }
\newlabel{fig:walking_psd_contrast}{{19}{12}{}{figure.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces Sensitivity analysis of respiratory-centered RR spectral power across three integration windows ($\pm $0.010, $\pm $0.015, $\pm $0.020~Hz) around each imposed breathing frequency. All three bandwidths show monotonic increase from 12 to 3~breaths/min with no isolated peak at 6~breaths/min (dashed vertical line).}}{13}{}\protected@file@percent }
