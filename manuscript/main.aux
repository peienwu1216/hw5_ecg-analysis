\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {III-A}}Postural Baseline Showed the Expected Orthostatic HRV Pattern (\textbf  {H1 Supported})}{4}{}\protected@file@percent }
\newlabel{ssec:posture}{{\mbox  {III-A}}{4}{}{subsection.3.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {III-B}}Inspiratory and Expiratory Breath-Hold Produced Different HR Responses (\textbf  {H2 Supported})}{4}{}\protected@file@percent }
\newlabel{ssec:breathhold}{{\mbox  {III-B}}{4}{}{subsection.3.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {III}{\ignorespaces Postural Baseline HRV Summary}}{4}{}\protected@file@percent }
\newlabel{tab:posture}{{III}{4}{}{table.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Postural RR tachograms (top row) and RR interval power spectral density (bottom row) for supine, sitting, and standing conditions. RR intervals are displayed in seconds. Beat-to-beat successive differences are visible as the point-to-point variations in the tachogram, showing clearly larger amplitude in supine than in standing. Shaded regions indicate LF (orange) and HF (teal) bands per Task Force definitions~\cite  {taskforce1996}. HF power decreases monotonically from supine to standing, consistent with progressive vagal withdrawal.}}{4}{}\protected@file@percent }
\newlabel{fig:posture}{{2}{4}{}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces ECG power spectral density (0.05--5~Hz) reveals heartbeat fundamental frequency, harmonics, and respiratory modulation across postures. The fundamental frequency $f_{0}$ shifts from $\sim $0.90~Hz (supine, HR\,=\,54.0~bpm) to $\sim $1.33~Hz (standing, HR\,=\,79.7~bpm). Harmonic peaks at $2f_{0}$ and $3f_{0}$ are clearly visible, consistent with the QRS complex morphology. The breathing frequency is identifiable as a low-frequency modulation peak in supine recordings. Direct response to assignment Q1: heartbeat frequency, harmonics, and breathing frequency are all observable.}}{5}{}\protected@file@percent }
\newlabel{fig:ecg_psd}{{3}{5}{}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Poincar\'e return maps ($\text  {RR}_{n+1}$ vs.\ $\text  {RR}_{n}$) for supine, sitting, and standing conditions. The scatter cloud contracts progressively from supine to standing, reflecting reduced short-term vagal modulation consistent with the RMSSD decrease shown in Table~\ref {tab:posture}.}}{5}{}\protected@file@percent }
\newlabel{fig:poincare}{{4}{5}{}{figure.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {III-C}}Walking Increased HR but Limited Fine-Scale HRV Interpretation (\textbf  {H3 Supported})}{5}{}\protected@file@percent }
\newlabel{ssec:walking}{{\mbox  {III-C}}{5}{}{subsection.3.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {IV}{\ignorespaces Breath-Hold Trial-Level Metrics. Trial~1 = effortful hold; Trial~2 = relaxed hold (see Fig.~\ref {fig:breathhold}). HF power is reported for the relaxed trial only, because the opposing HR-slope directions between trials ($-$0.19 vs.\ +0.18~bpm/s for inspiratory) violate the stationarity assumption required for ensemble spectral averaging.}}{5}{}\protected@file@percent }
\newlabel{tab:breathhold}{{IV}{5}{}{table.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Breath-hold effort comparison. Inspiratory hold (top panels) produces larger HR excursions and more variable response shapes than expiratory hold (bottom panels), suggesting that conscious effort may modulate the physiological response beyond the respiratory perturbation alone.}}{5}{}\protected@file@percent }
\newlabel{fig:breathhold}{{5}{5}{}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Breath-hold spectral dynamics (relaxed trial only). (a)~HF power collapses during hold relative to the E1B seated anchor (1123~ms$^{2}$): inspiratory hold shows a 28.7-fold reduction ($-$96.5\%) versus a 4.9-fold reduction ($-$79.4\%) for expiratory hold. Both conditions recover to near-anchor levels ($\times $1.07--1.08), indicating a transient vagal perturbation that returned toward baseline. (b)--(d)~Representative inspiratory-relaxed trial showing the RR tachogram, time--frequency spectrogram, and instantaneous LF/HF power trajectories.}}{6}{}\protected@file@percent }
\newlabel{fig:hf_collapse}{{6}{6}{}{figure.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {V}{\ignorespaces Walking Challenge Segment Metrics}}{6}{}\protected@file@percent }
\newlabel{tab:walking}{{V}{6}{}{table.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Walking experiment overview. (a)~RR tachogram showing the autonomic response across seated, walking, and recovery segments. HR rises sharply at walk onset and decays exponentially during recovery ($\tau = 6.8$~s). (b)~Accelerometer magnitude with 2-s RMS envelope. Segment-level motion RMS confirmed minimal motion during seated (0.036~g) and recovery (0.042~g), with elevated but moderate motion during walking (0.103~g). Time-domain Pearson correlation between $|\Delta \mathrm  {RR}|$ and accelerometer magnitude was $r = 0.26$.}}{6}{}\protected@file@percent }
\newlabel{fig:walk_motion}{{7}{6}{}{figure.7}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {III-D}}Paced Breathing: Entrainment Manipulation Check, LF/HF Band Migration (\textbf  {H5}), and Resonance (\textbf  {H4})}{6}{}\protected@file@percent }
\newlabel{ssec:paced}{{\mbox  {III-D}}{6}{}{subsection.3.4}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {\mbox  {III-D}1}Frequency Entrainment Was Quantitatively Verified}{6}{}\protected@file@percent }
\citation{lehrer2014}
\citation{billman2013}
\citation{taskforce1996}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Post-walking heart rate recovery fitted to a single-exponential decay (Eq.~\ref {eq:recovery}). The time constant $\tau = 6.8$~s and HRR$_{60} = 18.5$~bpm indicate rapid parasympathetic reactivation consistent with low-intensity exercise. Grey circles: beat-to-beat HR; red curve: fitted model $\mathrm  {HR}(t) = A \cdot e^{-t/\tau } + C$.}}{7}{}\protected@file@percent }
\newlabel{fig:recovery_tau}{{8}{7}{}{figure.8}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {\mbox  {III-D}2}The Primary Effect Was Amplitude Expansion, Not Heart-Rate Reduction}{7}{}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {\mbox  {III-D}3}Respiratory-Centered Spectral Power Did Not Peak at 6~Breaths/Min (\textbf  {H4} Supported)}{7}{}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {\mbox  {III-D}4}LF/HF Inflation Dissociated from RMSSD, Supporting Spectral-Band Migration (\textbf  {H5} Supported)}{7}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Walking-phase ECG power spectral density showing elevated energy in the 1--3~Hz locomotor band coincident with the walking cadence. Motion artifacts contaminate the spectral content during ambulation, limiting fine-scale HRV interpretation.}}{7}{}\protected@file@percent }
\newlabel{fig:walk_ecg_psd}{{9}{7}{}{figure.9}{}}
